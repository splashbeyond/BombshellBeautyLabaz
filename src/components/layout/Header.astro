---
/**
 * Header — main navigation below the phone bar (sticky under scroll).
 *
 * • Brand on the left (text + optional logo).
 * • Nav links in the middle.
 * • Primary CTA on the right (hidden on mobile; phone bar covers it).
 * • Mobile: hamburger that opens an overlay nav.
 */
import { getSiteConfig } from '../../config/getSiteConfig';

const siteConfig = getSiteConfig(Astro.locals.siteVariant);
---

<header class="site-header" aria-label="Site header">
  <div class="site-header__inner container">
    <a href="/" class="site-header__brand" aria-label={`${siteConfig.business.name} — Home`}>
      {siteConfig.business.logoUrl ? (
        <img
          src={siteConfig.business.logoUrl}
          alt=""
          class="site-header__brand-logo"
          width="280"
          height="92"
          loading="eager"
          decoding="async"
        />
      ) : (
        <>
          <span class="site-header__brand-mark" aria-hidden="true">{siteConfig.business.name.charAt(0)}</span>
          <span class="site-header__brand-name">{siteConfig.business.name}</span>
        </>
      )}
    </a>

    <nav class="site-header__nav" aria-label="Primary">
      <ul class="site-header__nav-list">
        {siteConfig.nav.map((link) => (
          <li><a href={link.href} class="site-header__nav-link">{link.label}</a></li>
        ))}
      </ul>
    </nav>

    <div class="site-header__actions">
      <a href={`tel:${siteConfig.contact.phoneE164}`} class="site-header__phone-mini">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
          <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
        </svg>
        <span>{siteConfig.contact.phone}</span>
      </a>
      <a
        href={siteConfig.hero.primaryCta.href}
        class="btn btn-primary site-header__cta"
        {...(siteConfig.hero.primaryCta.href.startsWith('http') ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
      >
        {siteConfig.hero.primaryCta.label}
      </a>
      <button
        class="site-header__menu-btn"
        aria-label="Toggle menu"
        aria-expanded="false"
        aria-controls="mobile-nav"
        type="button"
      >
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <line x1="3" y1="6" x2="21" y2="6"></line>
          <line x1="3" y1="12" x2="21" y2="12"></line>
          <line x1="3" y1="18" x2="21" y2="18"></line>
        </svg>
      </button>
    </div>
  </div>

  <nav id="mobile-nav" class="site-header__mobile-nav" aria-label="Primary mobile">
    <ul>
      {siteConfig.nav.map((link) => (
        <li><a href={link.href}>{link.label}</a></li>
      ))}
      <li>
        <a
          href={siteConfig.hero.primaryCta.href}
          class="site-header__mobile-cta"
          {...(siteConfig.hero.primaryCta.href.startsWith('http') ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
        >{siteConfig.hero.primaryCta.label}</a>
      </li>
    </ul>
  </nav>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 90;
    background-color: var(--color-bg);
    border-bottom: 1px solid var(--color-border);
    backdrop-filter: blur(10px);
  }

  .site-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    min-height: 80px;
    padding-block: 0.875rem 1rem;
  }

  .site-header__brand {
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
    color: var(--color-text);
    font-family: var(--font-display);
    font-weight: var(--type-weight-display);
    font-size: 1.25rem;
    letter-spacing: -0.02em;
    text-decoration: none;
    flex-shrink: 0;
  }
  .site-header__brand:hover { text-decoration: none; color: var(--color-text); }

  .site-header__brand-mark {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: var(--radius-md);
    background-color: var(--color-primary);
    color: var(--color-primary-fg);
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.125rem;
    letter-spacing: -0.02em;
  }

  .site-header__brand-logo {
    display: block;
    height: clamp(52px, 9vw, 84px);
    width: auto;
    max-width: min(320px, 52vw);
    object-fit: contain;
    filter: drop-shadow(0 1px 2px rgba(26, 16, 20, 0.06));
  }

  .site-header__nav {
    display: none;
  }
  .site-header__nav-list {
    display: flex;
    gap: 1.75rem;
  }
  .site-header__nav-link {
    color: var(--color-text-muted);
    font-weight: var(--type-weight-body);
    font-size: 0.9375rem;
    letter-spacing: -0.005em;
    text-decoration: none;
    transition: color var(--motion-duration) var(--motion-easing);
  }
  .site-header__nav-link:hover {
    color: var(--color-text);
    text-decoration: none;
  }

  .site-header__actions {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .site-header__phone-mini {
    display: none;
    align-items: center;
    gap: 0.4rem;
    color: var(--color-text);
    font-weight: var(--type-weight-body-bold);
    font-size: 0.9375rem;
    font-variant-numeric: tabular-nums;
  }
  .site-header__phone-mini:hover { color: var(--color-primary); text-decoration: none; }

  .site-header__cta { display: none; }

  .site-header__menu-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    color: var(--color-text);
    border-radius: var(--radius-sm);
    transition: background-color var(--motion-duration) var(--motion-easing);
  }
  .site-header__menu-btn:hover { background-color: var(--color-surface-alt); }

  .site-header__mobile-nav {
    display: none;
    background-color: var(--color-bg);
    border-bottom: 1px solid var(--color-border);
  }
  .site-header__mobile-nav.is-open { display: block; }
  .site-header__mobile-nav ul {
    padding: 1rem var(--space-container-pad);
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .site-header__mobile-nav a {
    display: block;
    padding: 0.875rem 0.5rem;
    color: var(--color-text);
    font-weight: var(--type-weight-body-bold);
    border-radius: var(--radius-sm);
  }
  .site-header__mobile-nav a:hover { background-color: var(--color-surface-alt); text-decoration: none; }
  .site-header__mobile-cta {
    background-color: var(--color-primary);
    color: var(--color-primary-fg) !important;
    text-align: center;
  }
  .site-header__mobile-cta:hover { background-color: var(--color-primary-hover); color: var(--color-primary-fg) !important; }

  @media (min-width: 768px) {
    .site-header__nav { display: block; }
    .site-header__phone-mini { display: inline-flex; }
    .site-header__menu-btn { display: none; }
  }
  @media (min-width: 960px) {
    .site-header__cta { display: inline-flex; }
  }
</style>

<script is:inline>
  (() => {
    const btn = document.querySelector('.site-header__menu-btn');
    const nav = document.getElementById('mobile-nav');
    if (!btn || !nav) return;
    btn.addEventListener('click', () => {
      const isOpen = nav.classList.toggle('is-open');
      btn.setAttribute('aria-expanded', String(isOpen));
    });
  })();
</script>
