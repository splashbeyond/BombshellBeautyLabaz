---
/**
 * PhoneBar — top contact strip (scrolls with the page; not sticky).
 *
 * Per the SEO + conversion research:
 *   • Phone number with tel: link (E.164 in href, formatted display).
 *   • Click-to-call is the primary conversion event for service businesses.
 *   • Always-visible, 48px+ tap target.
 *   • Emergency text shown when emergencyService = true.
 */
import { getSiteConfig } from '../../config/getSiteConfig';
import { icons } from '../../config/icons';

const siteConfig = getSiteConfig(Astro.locals.siteVariant);
const c = siteConfig.contact;
const instagramUrl = siteConfig.social.instagram?.trim() || '';
---

<div class="phone-bar" role="region" aria-label="Contact information">
  <div class="phone-bar__inner container">
    {siteConfig.contact.emergencyService && (
      <span class="phone-bar__urgency" aria-hidden="true">
        <span class="phone-bar__pulse"></span>
        {c.emergencyText}
      </span>
    )}
    <div class="phone-bar__actions">
    {instagramUrl && (
      <a
        href={instagramUrl}
        class="phone-bar__instagram"
        target="_blank"
        rel="noopener noreferrer"
        aria-label={`${siteConfig.business.name} on Instagram`}
        data-cta="phone-bar-instagram"
      >
        <span class="phone-bar__instagram-icon" set:html={icons.instagram} />
      </a>
    )}
    <a href={`tel:${c.phoneE164}`} class="phone-bar__call" data-cta="phone-bar">
      <svg
        width="16"
        height="16"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2.5"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
      </svg>
      <span class="phone-bar__call-label">Call Now:</span>
      <span class="phone-bar__call-number">{c.phone}</span>
    </a>
    </div>
  </div>
</div>

<style>
  .phone-bar {
    position: relative;
    z-index: 100;
    background-color: var(--color-text);
    color: var(--color-bg);
    font-size: 0.875rem;
    line-height: 1;
    border-bottom: 1px solid var(--color-border-strong);
  }

  .phone-bar__inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    min-height: 44px;
    padding-block: 0.5rem;
    gap: 1rem;
  }

  .phone-bar__actions {
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
    margin-left: auto;
  }

  .phone-bar__instagram {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--color-bg);
    padding: 0.5rem;
    margin: -0.5rem 0;
    border-radius: var(--radius-sm);
    line-height: 0;
    transition: opacity var(--motion-duration) var(--motion-easing);
  }
  .phone-bar__instagram:hover {
    color: var(--color-bg);
    opacity: 0.85;
  }
  .phone-bar__instagram:focus-visible {
    outline: 2px solid var(--color-bg);
    outline-offset: 2px;
  }
  .phone-bar__instagram-icon :global(svg) {
    width: 18px;
    height: 18px;
    display: block;
  }

  .phone-bar__urgency {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--color-bg);
    font-weight: var(--type-weight-body-bold);
    letter-spacing: 0.005em;
  }

  .phone-bar__pulse {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background-color: var(--color-success);
    box-shadow: 0 0 0 0 currentColor;
    animation: phone-bar-pulse 2s ease-in-out infinite;
  }

  @keyframes phone-bar-pulse {
    0% { box-shadow: 0 0 0 0 rgba(46, 125, 91, 0.6); }
    70% { box-shadow: 0 0 0 6px rgba(46, 125, 91, 0); }
    100% { box-shadow: 0 0 0 0 rgba(46, 125, 91, 0); }
  }

  .phone-bar__call {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--color-bg);
    font-weight: var(--type-weight-body-bold);
    text-decoration: none;
    transition: color var(--motion-duration) var(--motion-easing);
    padding: 0.5rem 0.75rem;
    margin: -0.5rem -0.75rem;
    border-radius: var(--radius-sm);
  }
  .phone-bar__call:hover {
    color: var(--color-bg);
    text-decoration: underline;
  }
  .phone-bar__call:focus-visible {
    outline: 2px solid var(--color-bg);
    outline-offset: 2px;
  }

  .phone-bar__call-label {
    opacity: 0.85;
  }

  .phone-bar__call-number {
    font-variant-numeric: tabular-nums;
  }

  /* On smallest screens, hide the urgency text; the phone number is what matters. */
  @media (max-width: 480px) {
    .phone-bar__urgency {
      display: none;
    }
    .phone-bar__inner {
      justify-content: center;
    }
    .phone-bar__actions {
      margin-left: 0;
    }
  }
</style>
