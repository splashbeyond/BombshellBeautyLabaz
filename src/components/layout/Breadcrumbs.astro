---
/**
 * Visible breadcrumb navigation. Pair with BreadcrumbSchema for SEO benefit.
 */
import type { BreadcrumbItem } from '../seo/BreadcrumbSchema.astro';

interface Props {
  items: BreadcrumbItem[];
}

const { items } = Astro.props;
---

<nav class="breadcrumbs" aria-label="Breadcrumb">
  <ol class="container">
    {items.map((item, idx) => (
      <li>
        {idx < items.length - 1 ? (
          <>
            <a href={item.href}>{item.name}</a>
            <span class="breadcrumbs__sep" aria-hidden="true">/</span>
          </>
        ) : (
          <span aria-current="page">{item.name}</span>
        )}
      </li>
    ))}
  </ol>
</nav>

<style>
  .breadcrumbs {
    padding-block: 1rem;
    border-bottom: 1px solid var(--color-border);
    font-size: 0.875rem;
    color: var(--color-text-muted);
  }
  .breadcrumbs ol {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    align-items: center;
  }
  .breadcrumbs a {
    color: var(--color-text-muted);
    text-decoration: none;
  }
  .breadcrumbs a:hover { color: var(--color-primary); text-decoration: underline; }
  .breadcrumbs__sep { color: var(--color-text-subtle); }
  .breadcrumbs [aria-current="page"] {
    color: var(--color-text);
    font-weight: var(--type-weight-body-bold);
  }
</style>
