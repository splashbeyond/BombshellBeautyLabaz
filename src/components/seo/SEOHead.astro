---
/**
 * SEOHead — drop into <head> on every page.
 *
 * Responsibilities:
 *   • Title + meta description (with auto-template substitution)
 *   • Canonical URL (UTM-stripped)
 *   • OpenGraph + Twitter card meta
 *   • Robots meta with optimal Google directives
 *   • Search-engine verification tokens
 *   • Mobile viewport, theme-color, favicon
 *
 * Usage:
 *   <SEOHead
 *     title="Drain Cleaning"            (page-specific title; template wraps it)
 *     description="..."                 (page-specific meta description)
 *     image="/images/og-drain.jpg"      (optional OG override)
 *     noindex={false}                   (optional)
 *   />
 */
import { getSiteConfig } from '../../config/getSiteConfig';

const siteConfig = getSiteConfig(Astro.locals.siteVariant);

export interface Props {
  title?: string;
  description?: string;
  image?: string;
  noindex?: boolean;
  type?: 'website' | 'article';
  publishedTime?: string;
  modifiedTime?: string;
  author?: string;
}

const {
  title,
  description = siteConfig.seo.description,
  image = siteConfig.seo.ogImage,
  noindex = false,
  type = 'website',
  publishedTime,
  modifiedTime,
  author,
} = Astro.props;

// Compose final title using the template from site.config.
const fullTitle = title
  ? siteConfig.seo.titleTemplate
      .replace('{title}', title)
      .replace('{business}', siteConfig.business.name)
  : siteConfig.seo.defaultTitle;

// Build canonical URL — strip UTM params and other tracking noise.
const canonicalUrl = new URL(Astro.url.pathname, siteConfig.url);
canonicalUrl.search = '';

// Build absolute OG image URL.
const ogImageUrl = new URL(image, siteConfig.url).toString();
---

<!-- Primary meta -->
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>{fullTitle}</title>
<meta name="description" content={description} />
{siteConfig.seo.keywords.length > 0 && (
  <meta name="keywords" content={siteConfig.seo.keywords.join(', ')} />
)}

<!-- Canonical -->
<link rel="canonical" href={canonicalUrl.toString()} />

<!-- Robots: allow Google to display rich previews. -->
<meta
  name="robots"
  content={
    noindex
      ? 'noindex, nofollow'
      : 'index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1'
  }
/>

<!-- Search engine verification -->
{siteConfig.seo.googleSiteVerification && (
  <meta name="google-site-verification" content={siteConfig.seo.googleSiteVerification} />
)}
{siteConfig.seo.bingVerification && (
  <meta name="msvalidate.01" content={siteConfig.seo.bingVerification} />
)}

<!-- OpenGraph -->
<meta property="og:type" content={type} />
<meta property="og:site_name" content={siteConfig.business.name} />
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonicalUrl.toString()} />
<meta property="og:image" content={ogImageUrl} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:locale" content={siteConfig.seo.locale} />

{type === 'article' && publishedTime && (
  <meta property="article:published_time" content={publishedTime} />
)}
{type === 'article' && modifiedTime && (
  <meta property="article:modified_time" content={modifiedTime} />
)}
{type === 'article' && author && (
  <meta property="article:author" content={author} />
)}

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={fullTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImageUrl} />

<!-- Favicon -->
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="alternate icon" href="/favicon.ico" />
<link rel="apple-touch-icon" href="/apple-touch-icon.png" />
<meta name="theme-color" content="var(--color-bg)" />

<!-- DNS prefetch for performance -->
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
