---
/**
 * Practice spotlight — Moon Valley–style intro: offset photo panel + teal ribbons + serif headline + body.
 */
import { getSiteConfig } from '../../config/getSiteConfig';

const c = getSiteConfig(Astro.locals.siteVariant);
const ps = c.practiceSpotlight;
---

<section class="practice-spotlight section" id="practice-spotlight" aria-labelledby="practice-spotlight-heading">
  <div class="container">
    <div class="practice-spotlight__grid">
      <figure class="practice-spotlight__figure">
        <div class="practice-spotlight__figure-inner">
          <div class="practice-spotlight__photo-panel" aria-hidden="true"></div>
          <img
            class="practice-spotlight__img"
            src={ps.image}
            alt={ps.imageAlt}
            width="680"
            height="850"
            loading="lazy"
            decoding="async"
          />
        </div>
      </figure>

      <div class="practice-spotlight__copy">
        <p class="practice-spotlight__ribbon-top">{ps.ribbonTop}</p>
        <h2 id="practice-spotlight-heading" class="practice-spotlight__headline text-balance">
          {ps.headline}
        </h2>
        <div class="practice-spotlight__body" set:html={ps.bodyHtml} />
        {ps.bodyHtml2 && <div class="practice-spotlight__body" set:html={ps.bodyHtml2} />}
        {
          ps.ribbonBottom && (
            <p class="practice-spotlight__ribbon-bottom">{ps.ribbonBottom}</p>
          )
        }
      </div>
    </div>
  </div>
</section>

<style>
  .practice-spotlight {
    --practice-ribbon: #2d7d7c;
    background-color: var(--color-bg);
  }

  .practice-spotlight__grid {
    display: grid;
    gap: clamp(2.25rem, 5vw, 3.5rem);
    align-items: center;
  }

  @media (min-width: 900px) {
    .practice-spotlight__grid {
      grid-template-columns: minmax(0, 1fr) minmax(0, 1.05fr);
      gap: clamp(2.5rem, 5vw, 4rem);
    }
  }

  .practice-spotlight__figure {
    margin: 0;
    max-width: 440px;
    margin-inline: auto;
  }

  .practice-spotlight__figure-inner {
    position: relative;
    padding: 0 0 1rem 1rem;
  }

  /** Offset panel behind photo (pink / champagne wash — glam palette) */
  .practice-spotlight__photo-panel {
    position: absolute;
    top: -1rem;
    left: -1rem;
    width: calc(100% - 1.25rem);
    height: calc(100% - 0.5rem);
    background: linear-gradient(
      145deg,
      var(--color-surface-alt) 0%,
      rgba(251, 239, 241, 0.92) 55%,
      var(--color-surface-alt) 100%
    );
    border-radius: 3px;
    z-index: 0;
    box-shadow: 0 16px 48px rgba(26, 16, 20, 0.06);
  }

  .practice-spotlight__img {
    position: relative;
    z-index: 1;
    width: 100%;
    height: auto;
    display: block;
    border-radius: 2px;
    object-fit: cover;
    aspect-ratio: 4 / 5;
    box-shadow:
      0 20px 50px rgba(26, 16, 20, 0.12),
      0 0 0 1px rgba(240, 226, 229, 0.85);
  }

  .practice-spotlight__copy {
    text-align: center;
  }

  @media (min-width: 900px) {
    .practice-spotlight__copy {
      text-align: left;
    }
  }

  .practice-spotlight__ribbon-top,
  .practice-spotlight__ribbon-bottom {
    margin: 0 0 1rem;
    font-family: var(--font-body);
    font-size: clamp(0.625rem, 0.35vw + 0.52rem, 0.6875rem);
    font-weight: var(--type-weight-body-bold);
    letter-spacing: 0.11em;
    line-height: 1.55;
    text-transform: uppercase;
    color: var(--practice-ribbon);
  }

  .practice-spotlight__ribbon-bottom {
    margin-top: 1.75rem;
    margin-bottom: 0;
    padding-top: 1.25rem;
    border-top: 1px solid var(--color-border);
  }

  .practice-spotlight__headline {
    margin: 0 0 1.25rem;
    font-family: var(--font-display);
    font-size: clamp(2rem, 3vw + 1rem, 2.75rem);
    font-weight: var(--type-weight-display);
    line-height: var(--type-line-height-display);
    letter-spacing: var(--type-letter-spacing-display);
    color: var(--color-text);
  }

  .practice-spotlight__body {
    font-size: 1rem;
    line-height: 1.75;
    letter-spacing: var(--type-letter-spacing-body);
    color: var(--color-text-muted);
    text-wrap: pretty;
  }

  .practice-spotlight__body :global(p) {
    margin: 0 0 1rem;
    color: inherit;
  }

  .practice-spotlight__body :global(p:last-child) {
    margin-bottom: 0;
  }

  .practice-spotlight__body + .practice-spotlight__body {
    margin-top: 1rem;
  }

  .practice-spotlight__body :global(strong) {
    font-weight: var(--type-weight-body-bold);
    color: var(--color-text);
  }
</style>
