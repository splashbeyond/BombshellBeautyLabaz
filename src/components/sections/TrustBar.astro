---
/**
 * TrustBar — compact trust signals (homepage: above final CTA).
 */
import { getSiteConfig } from '../../config/getSiteConfig';

const siteConfig = getSiteConfig(Astro.locals.siteVariant);
import { starsHtml } from '../../config/icons';
const c = siteConfig;
---

<section class="trust-bar" aria-label="Trust and credentials">
  <div class="container trust-bar__inner">
    <div class="trust-bar__item">
      <span class="stars" aria-hidden="true" set:html={starsHtml(5)}></span>
      <div>
        <strong>{Math.round(c.trust.rating)} stars</strong>
      </div>
    </div>

    <div class="trust-bar__divider" aria-hidden="true"></div>

    <div class="trust-bar__item">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path d="M12 2L4 6v6c0 5 3.5 9.5 8 11 4.5-1.5 8-6 8-11V6l-8-4z"/>
        <path d="M9 12l2 2 4-4"/>
      </svg>
      <div>
        <strong>{c.trust.license.label}</strong>
      </div>
    </div>

    <div class="trust-bar__divider" aria-hidden="true"></div>

    <div class="trust-bar__item">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
        <circle cx="12" cy="7" r="4"/>
      </svg>
      <div>
        <strong>RN-Owned</strong>
        {c.business.foundedYear != null && (
          <span class="text-subtle"> · Est. {c.business.foundedYear}</span>
        )}
      </div>
    </div>

    <div class="trust-bar__divider" aria-hidden="true"></div>

    <div class="trust-bar__item">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
        <line x1="16" y1="2" x2="16" y2="6"/>
        <line x1="8" y1="2" x2="8" y2="6"/>
        <line x1="3" y1="10" x2="21" y2="10"/>
      </svg>
      <div>
        <strong>By Appointment Only</strong>
      </div>
    </div>
  </div>
</section>

<style>
  .trust-bar {
    background-color: var(--color-surface);
    border-block: 1px solid var(--color-border);
    padding-block: 1.5rem;
  }
  .trust-bar__inner {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 1rem 2rem;
  }
  .trust-bar__item {
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
    font-size: 0.9375rem;
  }
  .trust-bar__item strong { font-weight: var(--type-weight-body-bold); }
  .trust-bar__item svg { color: var(--color-primary); flex-shrink: 0; }
  .trust-bar__divider {
    display: none;
    width: 1px;
    height: 20px;
    background-color: var(--color-border-strong);
  }
  @media (min-width: 768px) {
    .trust-bar__divider { display: block; }
  }
</style>
