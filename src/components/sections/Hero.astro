---
/**
 * Hero — the most important section on the site.
 *
 * Per the conversion + SEO research:
 *   • H1 includes primary service + city (geographic specificity = ranking signal)
 *   • Three pieces of info answered in 3 seconds: what we do, where, why trust us
 *   • Dual CTAs: phone (urgent) + form (planned), visually distinct
 *   • Hero image is the LCP element — explicitly sized, eager-loaded, fetchpriority high
 *   • Image is FLUSH with the header on desktop, full-height of the hero column
 */
import { getSiteConfig } from '../../config/getSiteConfig';
import { starsHtml } from '../../config/icons';
import HeroCarousel from './HeroCarousel.astro';

const siteConfig = getSiteConfig(Astro.locals.siteVariant);

const c = siteConfig;
const useHeroCarousel = Boolean(c.heroCarousel?.enabled && c.heroCarousel.slides.length > 0);
const phoneHref = c.hero.primaryCta.href === 'tel:' ? `tel:${c.contact.phoneE164}` : c.hero.primaryCta.href;
const heroStars = starsHtml(Math.round(c.trust.rating));
const isPhoneCta = phoneHref.startsWith('tel:');
const isExternalCta = /^https?:\/\//.test(phoneHref);
---

{
  useHeroCarousel ? (
    <HeroCarousel />
  ) : (
<section class="hero section-hero">
  <div class="container hero__inner">
    <div class="hero__content">
      <span class="eyebrow hero__eyebrow">{c.hero.eyebrow}</span>
      <h1 class="hero__headline text-balance">{c.hero.headline}</h1>
      <p class="hero__sub text-pretty">{c.hero.subheadline}</p>

      <div class="hero__cta">
        <a
          href={phoneHref}
          class="btn btn-primary btn-large"
          data-cta="hero-primary"
          {...(isExternalCta ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
        >
          {isPhoneCta ? (
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
            </svg>
          ) : (
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
              <line x1="16" y1="2" x2="16" y2="6"></line>
              <line x1="8" y1="2" x2="8" y2="6"></line>
              <line x1="3" y1="10" x2="21" y2="10"></line>
            </svg>
          )}
          {c.hero.primaryCta.label === 'Call Now' ? `${c.hero.primaryCta.label}: ${c.contact.phone}` : c.hero.primaryCta.label}
        </a>
        {c.hero.secondaryCta && (
          <a
            href={c.hero.secondaryCta.href === 'tel:' ? `tel:${c.contact.phoneE164}` : c.hero.secondaryCta.href}
            class="btn btn-secondary btn-large"
            data-cta="hero-secondary"
          >
            {c.hero.secondaryCta.href.startsWith('tel:') ? (
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
              </svg>
            ) : null}
            {c.hero.secondaryCta.label}
            {!c.hero.secondaryCta.href.startsWith('tel:') && (
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                <path d="M5 12h14M13 5l7 7-7 7"></path>
              </svg>
            )}
          </a>
        )}
      </div>

      <div class="hero__signals">
        <div class="hero__signal">
          <span class="stars" aria-label={`${c.trust.rating} out of 5 stars`} set:html={heroStars}></span>
          <span><strong>{c.trust.rating}</strong> from <strong>{c.trust.reviewCount.toLocaleString()}</strong> reviews</span>
        </div>
        <div class="hero__signal-divider" aria-hidden="true"></div>
        <div class="hero__signal">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
            <path d="M9 12l2 2 4-4M12 2a10 10 0 1 0 0 20 10 10 0 0 0 0-20z"></path>
          </svg>
          <span>{c.trust.license.label}</span>
        </div>
        <div class="hero__signal-divider" aria-hidden="true"></div>
        <div class="hero__signal">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
            <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14M22 4l-10 10-3-3"></path>
          </svg>
          <span>
            {c.business.foundedYear != null
              ? `Appointment-only · Est. ${c.business.foundedYear}`
              : 'Appointment-only'}
          </span>
        </div>
      </div>
    </div>

    <div class="hero__visual" aria-hidden="false">
      <div class="hero__visual-frame">
        {c.hero.backgroundImage ? (
          <img
            src={c.hero.backgroundImage}
            alt={c.hero.backgroundAlt || ''}
            width="900"
            height="1100"
            loading="eager"
            fetchpriority="high"
            decoding="async"
          />
        ) : (
          <div class="hero__visual-placeholder">
            <svg viewBox="0 0 100 100" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <rect x="20" y="25" width="60" height="50" rx="2" />
              <path d="M30 75V55h15v20M55 75V60h15v15" />
              <path d="M50 25V10M40 18l10-8 10 8" />
            </svg>
            <p>Hero image placeholder<br/><span>See /public/images/PROMPTS.md</span></p>
          </div>
        )}
      </div>

      <div class="hero__floating-card">
        <div class="hero__floating-card-rating">
          <span class="stars" set:html={starsHtml(5)}></span>
          <strong>{c.trust.rating}</strong>
        </div>
        <p class="hero__floating-card-quote">
          "{c.trust.guarantee}"
        </p>
      </div>
    </div>
  </div>
</section>
  )
}

<style>
  /* The hero overrides the section-hero default top padding so the image
     can be flush with the header. The .hero__content column carries its
     own internal padding so the headline still has breathing room. */
  .section-hero {
    padding-block: 0 var(--space-section-pad);
  }

  .hero {
    position: relative;
    overflow: hidden;
  }

  .hero__inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    padding-block: var(--space-hero-pad) 0;
  }

  @media (min-width: 960px) {
    .hero__inner {
      grid-template-columns: minmax(0, 1.05fr) minmax(0, 0.95fr);
      gap: 4rem;
      padding-block: 0;
      align-items: stretch;
    }
    .hero__content {
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding-block: clamp(2.5rem, 5vw, 4.5rem);
    }
  }

  .hero__eyebrow {
    margin-bottom: 1.25rem;
    /* Brand name reads clearer than global eyebrow small-caps */
    text-transform: none;
    letter-spacing: 0.02em;
    font-size: clamp(1rem, 1vw + 0.85rem, 1.1875rem);
    font-family: var(--font-display);
    font-weight: var(--type-weight-display);
  }

  .hero__headline {
    font-size: clamp(2.25rem, 5vw + 1rem, 4.5rem);
    line-height: var(--type-line-height-display);
    letter-spacing: var(--type-letter-spacing-display);
    margin-bottom: 1.5rem;
  }

  .hero__sub {
    font-size: clamp(1.0625rem, 0.5vw + 1rem, 1.25rem);
    line-height: 1.6;
    color: var(--color-text-muted);
    max-width: 50ch;
    margin-bottom: 2rem;
  }

  .hero__cta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.875rem;
    margin-bottom: 2.25rem;
  }

  .hero__signals {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1rem;
    color: var(--color-text-muted);
    font-size: 0.9375rem;
  }

  .hero__signal {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }
  .hero__signal strong { color: var(--color-text); font-weight: var(--type-weight-body-bold); }

  .hero__signal-divider {
    width: 1px;
    height: 16px;
    background-color: var(--color-border-strong);
  }

  /* --- Visual: flush with header on desktop, taller column ------------- */
  .hero__visual {
    position: relative;
    display: flex;
    flex-direction: column;
  }

  .hero__visual-frame {
    position: relative;
    aspect-ratio: 4 / 5;
    border-radius: var(--radius-lg);
    overflow: hidden;
    background-color: var(--color-surface-alt);
    box-shadow: var(--shadow-lg);
    flex: 1;
  }

  @media (min-width: 960px) {
    .hero__visual-frame {
      aspect-ratio: auto;
      min-height: 620px;
      height: 100%;
    }
  }

  .hero__visual-frame img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero__visual-placeholder {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    color: var(--color-text-subtle);
    text-align: center;
    padding: 2rem;
  }
  .hero__visual-placeholder svg { width: 80px; height: 80px; opacity: 0.5; }
  .hero__visual-placeholder p { font-size: 0.875rem; line-height: 1.5; }
  .hero__visual-placeholder span { font-size: 0.75rem; }

  .hero__floating-card {
    position: absolute;
    bottom: -1.5rem;
    left: -1.5rem;
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: 1.125rem 1.25rem;
    box-shadow: var(--shadow-lg);
    max-width: 320px;
  }
  @media (min-width: 1100px) {
    .hero__floating-card { left: -3rem; }
  }
  @media (max-width: 480px) {
    .hero__floating-card { display: none; }
  }
  .hero__floating-card-rating {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.5rem;
  }
  .hero__floating-card-rating strong {
    font-size: 1.125rem;
    font-weight: var(--type-weight-body-bold);
  }
  .hero__floating-card-quote {
    font-size: 0.875rem;
    line-height: 1.5;
    color: var(--color-text-muted);
    font-style: italic;
  }
</style>
