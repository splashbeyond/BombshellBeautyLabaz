---
/**
 * FAQ — accordion of frequently asked questions.
 * Pairs with FAQSchema for AI Overview citations and featured snippets.
 *
 * Each answer should be a self-contained paragraph (the AI Overview-friendly format).
 */
import type { FaqItem } from '../../config/types';

interface Props {
  items: FaqItem[];
  title?: string;
  description?: string;
  /** Use 'h3' on service pages, 'h2' on homepage. */
  headingLevel?: 'h2' | 'h3';
}

const {
  items,
  title = 'Frequently Asked Questions',
  description,
  headingLevel = 'h2',
} = Astro.props;

const HeadingTag = headingLevel === 'h2' ? 'h2' : 'h3';
---

<section id="faq" class="section">
  <div class="container container-narrow">
    <header class="section__header reveal">
      <span class="eyebrow">FAQ</span>
      <HeadingTag>{title}</HeadingTag>
      {description && <p class="section__lede text-muted text-pretty">{description}</p>}
    </header>

    <div class="faq-list reveal">
      {items.map((item, i) => (
        <details class="faq-item" name="faq-group" open={i === 0}>
          <summary>
            <span>{item.question}</span>
            <svg class="faq-item__chevron" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
              <path d="M6 9l6 6 6-6"></path>
            </svg>
          </summary>
          <div class="faq-item__body">
            <p>{item.answer}</p>
          </div>
        </details>
      ))}
    </div>
  </div>
</section>

<style>
  .section__header {
    margin-bottom: 2.5rem;
    text-align: center;
  }
  .section__header h2,
  .section__header h3 { margin-block: 0.75rem 1rem; }
  .section__lede { font-size: 1.0625rem; line-height: 1.6; }

  .faq-list {
    border-top: 1px solid var(--color-border);
  }

  .faq-item {
    border-bottom: 1px solid var(--color-border);
  }

  .faq-item summary {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    padding-block: 1.25rem;
    list-style: none;
    cursor: pointer;
    font-family: var(--font-display);
    font-weight: var(--type-weight-display);
    font-size: 1.125rem;
    line-height: 1.4;
    color: var(--color-text);
    letter-spacing: -0.01em;
    transition: color var(--motion-duration) var(--motion-easing);
  }
  .faq-item summary::-webkit-details-marker { display: none; }
  .faq-item summary:hover { color: var(--color-primary); }
  .faq-item summary:focus-visible {
    outline: none;
    box-shadow: var(--shadow-focus);
    border-radius: var(--radius-sm);
  }

  .faq-item__chevron {
    color: var(--color-text-muted);
    transition: transform var(--motion-duration) var(--motion-easing);
    flex-shrink: 0;
  }
  .faq-item[open] .faq-item__chevron { transform: rotate(180deg); }

  .faq-item__body {
    padding: 0 0 1.5rem 0;
    color: var(--color-text-muted);
    font-size: 1rem;
    line-height: 1.65;
    max-width: 64ch;
  }
</style>
