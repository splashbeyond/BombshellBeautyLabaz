---
/**
 * Process — "How It Works" section. 3–4 steps maximum.
 * Reduces commitment anxiety by making the experience feel predictable.
 */
import { getSiteConfig } from '../../config/getSiteConfig';

const siteConfig = getSiteConfig(Astro.locals.siteVariant);
const steps = siteConfig.process;
---

<section id="process" class="section">
  <div class="container">
    <header class="section__header reveal">
      <span class="eyebrow">How It Works</span>
      <h2>Four steps. Zero pressure.</h2>
      <p class="section__lede text-muted text-pretty">
        From the moment you book to your post-treatment glow — here's what to expect.
      </p>
    </header>

    <div class="process-grid">
      {steps.map((step, i) => (
        <div class="process-step reveal" style={`transition-delay: ${i * 100}ms`}>
          <div class="process-step__number-row">
            <div class="process-step__number">
              <span class="process-step__number-text">{step.step}</span>
              {i < steps.length - 1 && (
                <span class="process-step__line" aria-hidden="true"></span>
              )}
            </div>
          </div>
          <h3>{step.title}</h3>
          <p class="text-muted">{step.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .section__header {
    max-width: 640px;
    margin: 0 auto 3.5rem;
    text-align: center;
  }
  .section__header h2 { margin-block: 0.75rem 1rem; }
  .section__lede { font-size: 1.125rem; line-height: 1.6; }

  .process-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    counter-reset: process-counter;
  }
  @media (min-width: 768px) {
    .process-grid { grid-template-columns: repeat(4, 1fr); gap: 1.5rem; }
  }

  .process-step {
    position: relative;
    text-align: left;
  }
  @media (min-width: 768px) {
    .process-step { text-align: center; }
  }

  .process-step__number-row {
    display: flex;
    justify-content: center;
    margin-bottom: 1.25rem;
  }

  .process-step__number {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: 999px;
    background-color: var(--color-primary);
    color: var(--color-primary-fg);
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.125rem;
  }

  .process-step__line {
    display: none;
    position: absolute;
    left: 100%;
    top: 50%;
    width: calc(100% - 2rem);
    height: 1px;
    background: linear-gradient(to right, var(--color-border-strong), transparent);
    transform: translateX(0.5rem);
  }
  @media (min-width: 768px) {
    .process-step__line { display: block; }
  }

  .process-step h3 {
    font-size: 1.25rem;
    margin-bottom: 0.5rem;
  }

  .process-step p {
    font-size: 0.9375rem;
    line-height: 1.55;
  }
</style>
