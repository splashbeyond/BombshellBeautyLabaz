---
/**
 * BaseLayout — wraps every page in the site.
 *
 * Responsibilities:
 *   • Read the active theme from siteConfig.theme
 *   • Inject the theme's CSS custom properties as inline <style>
 *   • Load the theme's Google Fonts (with preconnect + display=swap)
 *   • Include SEOHead, LocalBusinessSchema (everywhere), and any extra schema
 *   • Render skip link, phone bar (scrolls), sticky header, main, footer
 *   • Set up the IntersectionObserver for `.reveal` scroll animations
 */
import { getSiteConfig } from '../config/getSiteConfig';

const siteConfig = getSiteConfig(Astro.locals.siteVariant);
import { themes, themeToCssVars } from '../config/themes';
import SEOHead from '../components/seo/SEOHead.astro';
import LocalBusinessSchema from '../components/seo/LocalBusinessSchema.astro';
import PhoneBar from '../components/layout/PhoneBar.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import '../styles/global.css';

export interface Props {
  title?: string;
  description?: string;
  image?: string;
  noindex?: boolean;
  type?: 'website' | 'article';
  publishedTime?: string;
  modifiedTime?: string;
  author?: string;
  /** Optional override for the lang attribute. Defaults to en. */
  lang?: string;
}

const {
  title,
  description,
  image,
  noindex,
  type,
  publishedTime,
  modifiedTime,
  author,
  lang = 'en',
} = Astro.props;

const activeTheme = themes[siteConfig.theme];
const themeCss = themeToCssVars(activeTheme);
---

<!doctype html>
<html lang={lang} data-theme={siteConfig.theme}>
  <head>
    <SEOHead
      title={title}
      description={description}
      image={image}
      noindex={noindex}
      type={type}
      publishedTime={publishedTime}
      modifiedTime={modifiedTime}
      author={author}
    />
    <!-- Inject active theme's CSS custom properties -->
    <style is:inline set:html={themeCss}></style>

    <!-- Theme-specific Google Font -->
    <link rel="stylesheet" href={activeTheme.fonts.googleFontsUrl} />

    <!-- LocalBusiness schema on every page -->
    <LocalBusinessSchema />

    <slot name="head" />
  </head>
  <body>
    <a href="#main" class="skip-link sr-only">Skip to main content</a>
    <div class="site-shell">
      <PhoneBar />
      <Header />
      <main id="main">
        <slot />
      </main>
      <Footer />
    </div>

    <!-- Tiny scroll-reveal observer (≈400 bytes, no library) -->
    <script is:inline>
      (() => {
        const els = document.querySelectorAll('.reveal');
        if (!('IntersectionObserver' in window) || els.length === 0) {
          els.forEach((el) => el.classList.add('is-visible'));
          return;
        }
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((e) => {
              if (e.isIntersecting) {
                e.target.classList.add('is-visible');
                io.unobserve(e.target);
              }
            });
          },
          { rootMargin: '0px 0px -8% 0px', threshold: 0.05 },
        );
        els.forEach((el) => io.observe(el));
      })();
    </script>
  </body>
</html>
