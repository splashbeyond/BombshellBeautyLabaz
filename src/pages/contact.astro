---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/layout/Breadcrumbs.astro';
import BreadcrumbSchema from '../components/seo/BreadcrumbSchema.astro';
import { getSiteConfig } from '../config/getSiteConfig';
import { formatTime12h } from '../utils/formatTime';

const siteConfig = getSiteConfig(Astro.locals.siteVariant);

const c = siteConfig;
const breadcrumbs = [
  { name: 'Home', href: '/' },
  { name: 'Contact', href: '/contact/' },
];

const a = c.contact.address;
const addressLine = `${a.street}, ${a.city}, ${a.state} ${a.zip}`;
const mapsLink = `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(addressLine)}`;
const mapEmbedUrl = `https://www.google.com/maps?q=${c.contact.geo.lat},${c.contact.geo.lng}&z=16&output=embed`;
const hasPublishedHours = c.contact.hours.length > 0;
---

<BaseLayout
  title="Contact & Booking"
  description={`Book your appointment at ${c.business.name} in ${c.serviceArea.primaryCity}, ${c.contact.address.state}. By appointment only. Call ${c.contact.phone} or book online.`}
>
  <Fragment slot="head">
    <BreadcrumbSchema items={breadcrumbs} />
  </Fragment>

  <Breadcrumbs items={breadcrumbs} />

  <section class="contact-hero section-hero">
    <div class="container">
      <div class="contact-hero__inner">
        <div>
          <span class="eyebrow">Book or get in touch</span>
          <h1 class="text-balance">Let's plan your visit.</h1>
          <p class="contact-hero__lede text-muted text-pretty">
            {c.business.name} is by appointment only. Call Lisa to request a visit at the
            Scottsdale studio.
          </p>

          <div class="contact-hero__cta">
            <a
              href={c.hero.primaryCta.href}
              class="btn btn-primary btn-large"
              {...(/^https?:\/\//.test(c.hero.primaryCta.href) ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
            >
              {c.hero.primaryCta.label}
            </a>
          </div>

          <div class="contact-info">
            <div class="contact-info__item">
              <span class="contact-info__label">Call us</span>
              <a href={`tel:${c.contact.phoneE164}`} class="contact-info__phone">{c.contact.phone}</a>
              {c.contact.emergencyService && (
                <span class="contact-info__urgency">{c.contact.emergencyText}</span>
              )}
            </div>

            <div class="contact-info__item">
              <span class="contact-info__label">Email</span>
              <a href={`mailto:${c.contact.email}`}>{c.contact.email}</a>
            </div>

            <div class="contact-info__item">
              <span class="contact-info__label">Visit</span>
              <address>
                {c.contact.address.street}<br />
                {c.contact.address.city}, {c.contact.address.state} {c.contact.address.zip}
              </address>
            </div>

            <div class="contact-info__item">
              <span class="contact-info__label">Hours</span>
              {hasPublishedHours ? (
                <ul class="contact-info__hours">
                  {c.contact.hours.map((h) => (
                    <li>
                      <strong>{h.day}</strong>
                      <span>
                        {h.closed
                          ? 'Closed'
                          : `${formatTime12h(h.open!)} – ${formatTime12h(h.close!)}`}
                      </span>
                    </li>
                  ))}
                </ul>
              ) : (
                <p class="text-muted">By appointment. GBP does not list public hours yet.</p>
              )}
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="service-area" class="section section-alt">
    <div class="container">
      <header class="section__header">
        <span class="eyebrow">Studio location</span>
        <h2>Visit us in {c.serviceArea.primaryCity}</h2>
        <p class="section__lede text-muted text-pretty">{c.serviceArea.sectionIntro}</p>
      </header>
      <div class="contact-area-grid">
        <div class="contact-area-info">
          <h3>Address &amp; building</h3>
          <address class="contact-area-address">
            <span>{c.business.name}</span>
            <span>{a.street}</span>
            <span>{a.city}, {a.state} {a.zip}</span>
          </address>
          <p class="contact-area-actions">
            <a href={mapsLink} target="_blank" rel="noopener noreferrer" class="contact-area-maps-link">
              Open in Google Maps
            </a>
            <span class="text-muted" aria-hidden="true"> · </span>
            <a href={`tel:${c.contact.phoneE164}`}>{c.contact.phone}</a>
          </p>
          {c.serviceArea.studioDetails.map((paragraph) => (
            <p class="contact-area-detail text-muted">{paragraph}</p>
          ))}
        </div>
        <div class="contact-area-map">
          <iframe
            src={mapEmbedUrl}
            width="100%"
            height="400"
            style="border:0;"
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title={`Map: ${c.business.name}, ${addressLine}`}
          ></iframe>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .contact-hero__inner {
    max-width: 640px;
  }

  .contact-hero__lede {
    margin-block: 1rem 1.5rem;
    font-size: 1.125rem;
    line-height: 1.6;
    max-width: 50ch;
  }
  .contact-hero__cta {
    margin-bottom: 2.5rem;
  }

  .contact-info {
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
  }

  .contact-info__item {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .contact-info__label {
    font-size: 0.75rem;
    font-weight: var(--type-weight-body-bold);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .contact-info__phone {
    font-family: var(--font-display);
    font-size: 1.875rem;
    font-weight: var(--type-weight-display);
    color: var(--color-primary);
    font-variant-numeric: tabular-nums;
    letter-spacing: -0.02em;
  }
  .contact-info__phone:hover { color: var(--color-primary-hover); text-decoration: none; }

  .contact-info__urgency {
    color: var(--color-success);
    font-weight: var(--type-weight-body-bold);
    font-size: 0.875rem;
  }

  .contact-info__hours {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
    font-size: 0.9375rem;
    color: var(--color-text-muted);
    line-height: 1.4;
  }
  .contact-info__hours li {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    max-width: 280px;
  }
  .contact-info__hours strong { color: var(--color-text); font-weight: var(--type-weight-body-bold); }

  address { font-style: normal; color: var(--color-text-muted); line-height: 1.6; }

  .section__header {
    max-width: 640px;
    margin: 0 auto 2.5rem;
    text-align: center;
  }
  .section__header h2 {
    margin-block: 0.75rem 1rem;
  }
  .section__lede {
    margin: 0;
    font-size: 1.0625rem;
    line-height: 1.6;
  }

  .contact-area-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    align-items: start;
  }
  @media (min-width: 768px) {
    .contact-area-grid {
      grid-template-columns: 1fr 1.35fr;
      gap: 3rem;
    }
  }

  .contact-area-info h3 {
    margin: 0 0 1rem;
    font-size: 1.125rem;
  }
  .contact-area-address {
    margin: 0 0 0.75rem;
    font-style: normal;
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    font-size: 1rem;
    line-height: 1.5;
    color: var(--color-text);
  }
  .contact-area-address span:first-child {
    font-weight: var(--type-weight-body-bold);
  }
  .contact-area-actions {
    margin: 0 0 1.25rem;
    font-size: 0.9375rem;
  }
  .contact-area-maps-link {
    font-weight: var(--type-weight-body-bold);
  }
  .contact-area-detail {
    margin: 0 0 0.85rem;
    font-size: 0.9375rem;
    line-height: 1.6;
  }
  .contact-area-detail:last-child {
    margin-bottom: 0;
  }

  .contact-area-map {
    border-radius: var(--radius-md);
    overflow: hidden;
    border: 1px solid var(--color-border);
    box-shadow: var(--shadow-sm);
  }
</style>
