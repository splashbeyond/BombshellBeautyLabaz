---
/**
 * Location pages — one per city in serviceArea.cities.
 *
 * IMPORTANT for SEO: each page MUST have locally-specific content. Generic
 * "we serve [city]" with a swapped name is a spam pattern Google deprioritizes.
 *
 * The agent that customizes this template should write 200+ unique words per
 * location: mention neighborhoods, weather, permit specifics, local landmarks.
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/layout/Breadcrumbs.astro';
import BreadcrumbSchema from '../../components/seo/BreadcrumbSchema.astro';
import ServicesGrid from '../../components/sections/ServicesGrid.astro';
import Testimonials from '../../components/sections/Testimonials.astro';
import CTA from '../../components/sections/CTA.astro';
import { getSiteConfig } from '../../config/getSiteConfig';
import { siteConfig as pathSource } from '../../config/site.config.v1';

export function getStaticPaths() {
  return pathSource.serviceArea.cities.map((city) => ({
    params: { slug: city.toLowerCase().replace(/\s+/g, '-') },
    props: { city },
  }));
}

const { city } = Astro.props;
const c = getSiteConfig(Astro.locals.siteVariant);

const breadcrumbs = [
  { name: 'Home', href: '/' },
  { name: 'Service Area', href: '/contact/#service-area' },
  { name: city, href: Astro.url.pathname },
];

const title = `Hair Salon Serving ${city}`;
const description = `${c.business.name} welcomes clients from ${city} for haircuts, color, blonding, and styling by appointment.`;

const primary = c.hero.primaryCta;
const primaryHref = primary.href === 'tel:' ? `tel:${c.contact.phoneE164}` : primary.href;
const primaryIsExternal = /^https?:\/\//.test(primaryHref);
---

<BaseLayout title={title} description={description}>
  <Fragment slot="head">
    <BreadcrumbSchema items={breadcrumbs} />
  </Fragment>

  <Breadcrumbs items={breadcrumbs} />

  <section class="loc-hero section-hero">
    <div class="container container-narrow text-center">
      <span class="eyebrow">Now serving {city}</span>
      <h1 class="text-balance">{title}</h1>
      <p class="loc-hero__lede text-muted text-pretty">
        {c.business.name} welcomes clients from {city} for appointment-only haircuts, color,
        blonding, and styling at the Scottsdale studio.
      </p>
      <div class="loc-hero__cta">
        <a
          href={primaryHref}
          class="btn btn-primary btn-large"
          {...(primaryIsExternal ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
        >
          {primary.label}
        </a>
        <a href={`tel:${c.contact.phoneE164}`} class="btn btn-secondary btn-large">Call {c.contact.phone}</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container container-narrow">
      <h2>Why {city} clients choose {c.business.name}</h2>
      <p class="text-muted">
        Bombshell Beauty Lab is the rebrand of Lisa Turley At Salon Studios, bringing Lisa's
        decades of Scottsdale hair experience into a bolder beauty-lab identity.
      </p>
      <p class="text-muted">
        Lisa's philosophy centers on balance: flattering color, precision shape, movement,
        healthy-looking hair, and practical styling guidance clients can use at home.
      </p>
    </div>
  </section>

  <ServicesGrid title={`Services available to ${city} clients`} description={`Haircuts, color, blonding, and styling guidance at ${c.business.name}.`} />
  <Testimonials />
  <CTA
    title={`${city} clients welcome.`}
    description="Call Lisa to request an appointment at the Scottsdale studio."
  />
</BaseLayout>

<style>
  .loc-hero { padding-block: clamp(3rem, 6vw, 5rem); }
  .loc-hero__lede {
    margin-block: 1rem 2rem;
    font-size: 1.125rem;
    line-height: 1.6;
  }
  .loc-hero__cta {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    justify-content: center;
  }
  h2 { margin-bottom: 1rem; }
  p { font-size: 1.0625rem; line-height: 1.7; max-width: 64ch; margin-inline: auto; }
  p + p { margin-top: 1rem; }
  em { color: var(--color-text-subtle); }
</style>
