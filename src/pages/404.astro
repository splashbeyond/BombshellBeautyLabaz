---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page Not Found" noindex>
  <section class="section section-hero">
    <div class="container text-center">
      <h1>Page not found</h1>
      <p class="text-muted" style="font-size:1.125rem;margin:1rem auto 2rem;max-width:50ch;">
        The page you're looking for doesn't exist, or it's been moved. Try one of these instead.
      </p>
      <div style="display:flex;gap:0.75rem;flex-wrap:wrap;justify-content:center;">
        <a href="/" class="btn btn-primary">Back to home</a>
        <a href="/services/" class="btn btn-secondary">View services</a>
        <a href="/contact/" class="btn btn-secondary">Contact us</a>
      </div>
    </div>
  </section>
</BaseLayout>
